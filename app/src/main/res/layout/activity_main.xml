<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secondaryRed"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txtOutput"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:textColor="@color/darkGrey"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnCalcEAG"
        app:layout_constraintVertical_bias="0.2" />

    <TextView
        android:id="@+id/txtTitleBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primaryRed"
        android:backgroundTintMode="add"
        android:ems="10"
        android:text="Diabetes Blood Sugar Calculator"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias=".5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/edtEAG"
        android:layout_width="173dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:ems="10"
        android:hint="0"
        android:importantForAutofill="no"
        android:inputType="number|numberDecimal"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textView2"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/edtA1C"
        android:layout_width="175dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:ems="10"
        android:hint="0.0"
        android:importantForAutofill="no"
        android:inputType="number|numberDecimal"
        android:textSize="20sp"
        app:layout_constraintBaseline_toBaselineOf="@+id/textView3"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Blood Sugar (eAG)"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/edtEAG"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtTitleBar" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="A1c"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/textView2"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <RadioGroup
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@+id/textView3"
        app:layout_constraintTop_toTopOf="@+id/btnCalcA1C">

        <RadioButton
            android:id="@+id/radADAG"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:onClick="radBtnFormulaToggleOnClick"
            android:text="ADAG Formula" />

        <RadioButton
            android:id="@+id/radDCCT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:onClick="radBtnFormulaToggleOnClick"
            android:text="DCCT Formula" />
    </RadioGroup>

    <Button
        android:id="@+id/btnCalcA1C"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/primaryRed"
        android:enabled="true"
        android:onClick="btnCalcA1cOnPress"
        android:text="CALCULATE A1C"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="@+id/edtA1C"
        app:layout_constraintTop_toBottomOf="@+id/edtA1C" />

    <Button
        android:id="@+id/btnCalcEAG"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/disabled"
        android:enabled="false"
        android:onClick="btnCalcEAGOnPress"
        android:text="CALCULATE EAG"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="@+id/btnCalcA1C"
        app:layout_constraintTop_toBottomOf="@+id/btnCalcA1C" />


</androidx.constraintlayout.widget.ConstraintLayout>